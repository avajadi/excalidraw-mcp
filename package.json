{
  "name": "excalidraw-mcp",
  "version": "1.2.0",
  "description": "MCP server that generates .excalidraw scene files from high-level shape specs.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "excalidraw-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "build:web": "npm --prefix web install && npm --prefix web run build",
    "start": "node dist/index.js",
    "relay": "node dist/relay.js",
    "dev": "tsc --watch"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.5.0"
  }
}
